# Stripe (set these in Netlify site/env variables)
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_PRICE_ID=price_your_10mo_monthly_price_id_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Used to build Stripe success/cancel URLs
APP_BASE_URL=https://your-netlify-app.netlify.app

# Optional (query string for return)
STRIPE_SUCCESS_QUERY=pro=success
STRIPE_CANCEL_QUERY=pro=cancel

